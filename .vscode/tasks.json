{
    "version": "2.0.0",
    "command": "g++",
    "args": [
        "-g",
        "${file}",
        //"C:/Coding/CS106/Library/util/random.h",
        "-I","C:\\Coding\\CS106\\Library\\util",
        "C:\\Coding\\CS106\\Library\\util\\random.cpp",
        "-o",
        "${fileDirname}/${fileBasenameNoExtension}.exe"
    ],
    "problemMatcher": {
        "owner": "cpp",
        "fileLocation": [
            "relative",
            "${workspaceRoot}"
        ],
        "pattern": {
            "regexp": "^(.*):(\\d+):(\\d+):\\s+(warning|error):\\s+(.*)$",
            "file": 1,
            "line": 2,
            "column": 3,
            "severity": 4,
            "message": 5
        }
    }
}

